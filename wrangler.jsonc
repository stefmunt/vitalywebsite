{
	"compatibility_date": "2026-03-12",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "vitalywebsite",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"routes": [
		{ "pattern": "vitalychauffeur.com/*", "zone_name": "vitalychauffeur.com" },
		{ "pattern": "www.vitalychauffeur.com/*", "zone_name": "vitalychauffeur.com" }
	]
}