---
import BaseLayout from '../layouts/BaseLayout.astro';
import Services from '../components/Services.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout
  title="Our Services"
  description="Airport transfers, corporate travel, VIP transport and private driver hire in Dublin. Vitaly Executive Chauffeur — premium service every time."
>
  <section class="pt-40 pb-20 px-4 bg-charcoal-900 text-center">
    <div class="max-w-3xl mx-auto">
      <p class="text-gold-400 text-sm tracking-[0.3em] uppercase mb-4">What We Offer</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6">Our Services</h1>
      <p class="text-white/60 text-lg leading-relaxed">
        From airport transfers to full-day executive hire, every journey is handled with
        precision and care.
      </p>
    </div>
  </section>

  <Services />
  <Contact />
</BaseLayout>
