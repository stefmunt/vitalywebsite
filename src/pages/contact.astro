---
import BaseLayout from '../layouts/BaseLayout.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout
  title="Contact Us"
  description="Book a chauffeur or get in touch with Vitaly Executive Chauffeur. Dublin airport transfers, corporate travel, and VIP transport available 24/7."
>
  <section class="pt-40 pb-20 px-4 bg-charcoal-900 text-center">
    <div class="max-w-3xl mx-auto">
      <p class="text-gold-400 text-sm tracking-[0.3em] uppercase mb-4">Get in Touch</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold mb-6">Contact Us</h1>
      <p class="text-white/60 text-lg leading-relaxed">
        Ready to book or have a question? We'll get back to you within the hour.
      </p>
    </div>
  </section>

  <Contact />
</BaseLayout>
