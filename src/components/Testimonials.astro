---
const testimonials = [
  {
    name: 'James O\'Brien',
    role: 'Managing Director',
    quote: 'Vitaly has been our go-to chauffeur service for corporate travel for over two years. Always punctual, discreet, and professional.',
  },
  {
    name: 'Sarah Connolly',
    role: 'Private Client',
    quote: 'Exceptional service from booking to drop-off. The vehicle was immaculate and the driver was incredibly courteous. Highly recommended.',
  },
  {
    name: 'Michael Flynn',
    role: 'Events Manager',
    quote: 'We use Vitaly for all our VIP guest transfers. They never let us down — the reliability and quality is second to none in Dublin.',
  },
];
---

<section id="testimonials" class="py-24 px-4 bg-charcoal-800">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-gold-400 text-sm tracking-[0.3em] uppercase mb-4">Client Reviews</p>
      <h2 class="font-serif text-4xl md:text-5xl font-bold">What Our Clients Say</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map(({ name, role, quote }) => (
        <div class="p-8 border border-white/10 rounded-lg flex flex-col gap-6">
          <div class="flex gap-1 text-gold-400">
            {Array(5).fill(null).map(() => <span>★</span>)}
          </div>
          <p class="text-white/70 leading-relaxed italic flex-1">"{quote}"</p>
          <div>
            <p class="font-semibold text-white">{name}</p>
            <p class="text-sm text-white/40">{role}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
