---
---

<section id="contact" class="py-24 px-4 bg-charcoal-800">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Info -->
      <div>
        <p class="text-gold-400 text-sm tracking-[0.3em] uppercase mb-4">Get in Touch</p>
        <h2 class="font-serif text-4xl md:text-5xl font-bold mb-6">Book Your Transfer</h2>
        <p class="text-white/60 leading-relaxed mb-10">
          Ready to travel in comfort? Contact us to discuss your requirements or make a booking.
          We'll respond within the hour.
        </p>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-gold-500/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-white/40 uppercase tracking-widest mb-1">Phone</p>
              <a href="tel:+353000000000" class="text-white hover:text-gold-400 transition-colors">+353 00 000 0000</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-gold-500/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-white/40 uppercase tracking-widest mb-1">Email</p>
              <a href="mailto:info@vitalychauffeur.ie" class="text-white hover:text-gold-400 transition-colors">info@vitalychauffeur.ie</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-gold-500/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-white/40 uppercase tracking-widest mb-1">Location</p>
              <p class="text-white">Dublin, Ireland</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Form -->
      <form
        action="https://submit-form.com/pl5RDzLOQ"
        method="POST"
        class="space-y-5"
      >
        <input type="hidden" name="_redirect" value="https://vitalychauffeur.ie/thank-you" />
        <input type="hidden" name="_botpoison" value="" id="botpoison-field" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block text-xs text-white/40 uppercase tracking-widest mb-2">Full Name</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              placeholder="John Smith"
              class="w-full bg-white/5 border border-white/10 focus:border-gold-500 rounded px-4 py-3 text-white placeholder-white/20 outline-none transition-colors"
            />
          </div>
          <div>
            <label for="phone" class="block text-xs text-white/40 uppercase tracking-widest mb-2">Phone</label>
            <input
              id="phone"
              name="phone"
              type="tel"
              placeholder="+353 ..."
              class="w-full bg-white/5 border border-white/10 focus:border-gold-500 rounded px-4 py-3 text-white placeholder-white/20 outline-none transition-colors"
            />
          </div>
        </div>

        <div>
          <label for="email" class="block text-xs text-white/40 uppercase tracking-widest mb-2">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            placeholder="you@example.com"
            class="w-full bg-white/5 border border-white/10 focus:border-gold-500 rounded px-4 py-3 text-white placeholder-white/20 outline-none transition-colors"
          />
        </div>

        <div>
          <label for="service" class="block text-xs text-white/40 uppercase tracking-widest mb-2">Service</label>
          <select
            id="service"
            name="service"
            class="w-full bg-charcoal-800 border border-white/10 focus:border-gold-500 rounded px-4 py-3 text-white outline-none transition-colors"
          >
            <option value="">Select a service...</option>
            <option>Airport Transfer</option>
            <option>Corporate Travel</option>
            <option>VIP / Luxury</option>
            <option>Private Driver (Day/Half-Day)</option>
            <option>Other</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-xs text-white/40 uppercase tracking-widest mb-2">Message</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            placeholder="Travel dates, pickup location, any special requirements..."
            class="w-full bg-white/5 border border-white/10 focus:border-gold-500 rounded px-4 py-3 text-white placeholder-white/20 outline-none transition-colors resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full py-4 bg-gold-500 hover:bg-gold-600 text-charcoal-900 font-semibold tracking-wide rounded transition-colors duration-200"
        >
          Send Enquiry
        </button>
      </form>

      <script>
        window._botpoisonKey = 'pk_32ba5972-8597-4d3b-8fb0-9767c10a8184';
        document.addEventListener('DOMContentLoaded', () => {
          if (window.botpoison) {
            window.botpoison.init({ publicKey: window._botpoisonKey });
          }
        });
      </script>
    </div>
  </div>
</section>
