---
const images = [
  { src: '/images/fleet-1.jpg', alt: 'Mercedes S-Class' },
  { src: '/images/fleet-2.jpg', alt: 'Rear cabin — leather detail' },
  { src: '/images/fleet-3.jpg', alt: 'Executive SUV' },
  { src: '/images/fleet-4.jpg', alt: 'Door handle, close' },
  { src: '/images/fleet-5.jpg', alt: 'Dublin Airport arrival' },
  { src: '/images/fleet-6.jpg', alt: 'Gloved hand, interior' },
];
---

<section id="gallery" class="py-32 px-6 lg:px-16 bg-ink-950">
  <div class="max-w-5xl">

    <div class="flex items-center gap-6 mb-24">
      <span class="text-[10px] tracking-[0.42em] uppercase text-stone-600 shrink-0">The fleet</span>
      <div class="h-px flex-1 bg-ink-700"></div>
    </div>

    <!-- Asymmetric editorial grid -->
    <div class="grid grid-cols-12 gap-3">
      {images.map(({ src, alt }, i) => {
        const wide = i === 0 || i === 3;
        return (
          <div
            class={[
              wide ? 'col-span-12 md:col-span-8' : 'col-span-12 md:col-span-4',
              wide ? 'aspect-video' : 'aspect-[4/3]',
              'bg-ink-800 overflow-hidden group cursor-default',
            ].join(' ')}
          >
            <div class="w-full h-full flex items-end p-5 border border-ink-700 group-hover:border-brass-500/20 transition-colors duration-500">
              <p class="text-[9px] tracking-[0.3em] uppercase text-stone-700 group-hover:text-stone-500 transition-colors duration-500">
                {alt}
              </p>
            </div>
          </div>
        );
      })}
    </div>

    <p class="mt-8 text-[9px] tracking-[0.22em] uppercase text-stone-700 text-right">
      Fleet images to follow
    </p>

  </div>
</section>
