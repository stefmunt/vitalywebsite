---
interface Props {
  testimonial?: boolean;
}
const { testimonial = true } = Astro.props;
---

<section id="about" class="py-32 px-6 lg:px-16 bg-ink-900">
  <div class="max-w-5xl">

    <div class="flex items-center gap-6 mb-24">
      <span class="text-[10px] tracking-[0.42em] uppercase text-stone-600 shrink-0">Philosophy</span>
      <div class="h-px flex-1 bg-ink-700"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">

      <!-- Statement -->
      <div>
        <blockquote
          class="font-serif font-light italic text-ivory-100 leading-[1.25] mb-12"
          style="font-size: clamp(1.6rem, 3.2vw, 2.5rem);"
        >
          "The standard we work to is the one most clients notice only in its absence."
        </blockquote>
        <p class="text-stone-400 text-sm leading-relaxed mb-10 max-w-sm">
          Vitaly Executive Chauffeur was built on a single conviction: that genuine luxury in transport means the complete absence of friction. No waiting, no uncertainty, no compromised vehicles. A driver who knows Dublin, a car that reflects your standards, and a service that respects your time.
        </p>
        <a
          href="/about"
          class="inline-flex items-center gap-3 text-[11px] tracking-[0.25em] uppercase text-ivory-200 link-underline"
        >
          About us
          <span class="text-brass-500">&rarr;</span>
        </a>
      </div>

      <!-- Testimonial aside -->
      {testimonial && (
        <div class="border-l border-ink-700 pl-10 lg:pl-14 flex flex-col justify-center">
          <p class="font-serif font-light italic text-stone-300 text-lg leading-relaxed mb-8">
            "Vitaly has been our first call for corporate transfers for over two years. Always there, always discreet."
          </p>
          <div class="flex items-center gap-4">
            <div class="h-px w-6 bg-brass-500 shrink-0"></div>
            <div>
              <p class="text-[10px] tracking-[0.28em] uppercase text-stone-600">James O'Brien</p>
              <p class="text-[10px] tracking-[0.28em] uppercase text-stone-700 mt-0.5">Managing Director</p>
            </div>
          </div>
        </div>
      )}

    </div>
  </div>
</section>
