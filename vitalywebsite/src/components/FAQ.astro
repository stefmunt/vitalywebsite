---
const faqs = [
  {
    id: 'faq-flight-tracking',
    question: 'Do you track flights for Dublin Airport transfers?',
    answer: 'Yes. We monitor every flight in real time using flight tracking software. If your plane lands 20 minutes early or two hours late, we adjust your pickup automatically — you don\'t need to call or send a message.',
  },
  {
    id: 'faq-delay',
    question: 'What if my flight is delayed?',
    answer: 'We wait up to 60 minutes from your actual landing time at no extra charge. If you are delayed beyond 60 minutes, additional waiting time is charged at €15 per 30-minute block. We\'ll always message you before any extra charge applies.',
  },
  {
    id: 'faq-payment',
    question: 'How do I pay?',
    answer: 'We accept all major credit and debit cards (Visa, Mastercard, Amex), cash, and bank transfer. Approved corporate accounts receive itemised monthly invoices with a full VAT breakdown — every journey is ready for your expense report.',
  },
  {
    id: 'faq-vat',
    question: 'Is VAT included in the price?',
    answer: 'Yes. Every price shown includes Irish VAT at the applicable rate. Your receipt or invoice will show the full VAT breakdown so you can reclaim it on business journeys.',
  },
  {
    id: 'faq-book-for-guest',
    question: 'Can I book a transfer for a client or guest?',
    answer: 'Yes, this is common for PA bookings and hotel concierge requests. Enter your own details as the booker, then add your guest\'s name and mobile number in the notes field. We\'ll send the driver\'s details directly to your guest.',
  },
  {
    id: 'faq-cancel',
    question: 'What is the cancellation policy?',
    answer: 'Cancellations made more than 24 hours before your scheduled pickup are free of charge. Cancellations within 24 hours are charged at 50% of the agreed fare. No-shows (driver arrived, client not reachable after 15 minutes) are charged at the full fare.',
  },
  {
    id: 'faq-corporate',
    question: 'Do you offer corporate accounts?',
    answer: 'Yes. Corporate accounts receive monthly invoicing, priority booking access, and volume discounts for regular users. To apply, email info@vitalychauffeur.com with your company name and estimated monthly journey volume — we typically respond within one business day.',
  },
  {
    id: 'faq-coverage',
    question: 'What areas outside Dublin do you cover?',
    answer: 'We cover all of Ireland. Frequently requested long-distance routes and their approximate flat rates: Dublin–Cork (approx. €350), Dublin–Galway (approx. €280), Dublin–Belfast (approx. €250), Dublin–Limerick (approx. €220). All prices include VAT. Contact us for an exact quote on any route.',
  },
];
---

<section
  id="faq"
  class="py-20 sm:py-24 px-4 bg-charcoal-800"
  aria-labelledby="faq-heading"
>
  <div class="max-w-7xl mx-auto">

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-14 lg:gap-20">

      <!-- Left column: header -->
      <div class="lg:sticky lg:top-28 lg:self-start">
        <span class="gold-rule" aria-hidden="true"></span>
        <p class="text-gold-400 text-xs tracking-[0.35em] uppercase mb-3">FAQ</p>
        <h2 id="faq-heading" class="font-serif text-3xl sm:text-4xl font-bold leading-tight mb-5">
          Questions people ask before booking
        </h2>
        <p class="text-white/55 text-base leading-relaxed mb-8">
          Didn't find your answer? WhatsApp or call — we reply within the hour.
        </p>
        <div class="flex flex-col sm:flex-row lg:flex-col gap-3">
          <!-- PLACEHOLDER: Replace phone number -->
          <a
            href="tel:+353XXXXXXXXX"
            class="inline-flex items-center gap-2 text-sm text-white/70 hover:text-gold-400 transition-colors"
            aria-label="Call Vitaly Executive Chauffeur"
          >
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            +353 [FILL IN]<!-- PLACEHOLDER: Replace with real phone -->
          </a>
          <a
            href="https://wa.me/353XXXXXXXXX?text=Hi%2C%20I%20have%20a%20question%20about%20booking"
            class="inline-flex items-center gap-2 text-sm text-[#25D366] hover:text-[#1da851] transition-colors"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Open WhatsApp chat with Vitaly Executive Chauffeur"
          >
            <!-- PLACEHOLDER: Replace WhatsApp number in href -->
            <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            WhatsApp us
          </a>
        </div>
      </div>

      <!-- Right column: accordion -->
      <div>
        <dl class="space-y-1" id="faq-accordion">
          {faqs.map(({ id, question, answer }, i) => (
            <div
              id={id}
              class="border-b border-white/8 last:border-b-0"
            >
              <dt>
                <button
                  class="w-full flex items-center justify-between gap-4 py-5
                         text-left text-white hover:text-gold-400 transition-colors
                         focus-visible:text-gold-400"
                  aria-expanded="false"
                  aria-controls={`${id}-answer`}
                  data-faq-trigger
                  data-target={`${id}-answer`}
                >
                  <span class="text-base font-medium leading-snug pr-2">
                    {question}
                  </span>
                  <!-- Plus/minus icon -->
                  <span
                    class="shrink-0 w-6 h-6 rounded-full border border-white/20 flex items-center
                           justify-center text-white/50 transition-all duration-200 faq-icon"
                    aria-hidden="true"
                  >
                    <svg class="w-3 h-3 faq-plus" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6v12M6 12h12"/>
                    </svg>
                    <svg class="w-3 h-3 faq-minus hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 12h12"/>
                    </svg>
                  </span>
                </button>
              </dt>
              <dd id={`${id}-answer`} class="faq-body">
                <div>
                  <p class="text-white/60 text-sm leading-relaxed pb-5 pr-10">
                    {answer}
                  </p>
                </div>
              </dd>
            </div>
          ))}
        </dl>
      </div>

    </div>
  </div>
</section>

<!-- JS handled by /app.js §7 (initFAQ) -->
