---
---

<section class="relative h-screen overflow-hidden">
  <!-- Full-bleed image: desaturated, warm-toned -->
  <div class="absolute inset-0">
    <img
      src="/images/mychauffeur.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover object-center"
      style="filter: saturate(0.55) sepia(0.18) brightness(0.85);"
      fetchpriority="high"
    />
    <!-- Gradient: strong at bottom-left to anchor the text, gentle elsewhere -->
    <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(12,11,9,0.75) 0%, rgba(12,11,9,0.3) 45%, rgba(12,11,9,0.15) 100%);"></div>
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(12,11,9,0.5) 0%, transparent 55%);"></div>
  </div>

  <!-- Editorial text: bottom-left -->
  <div class="relative z-10 h-full flex flex-col justify-end px-6 lg:px-16 pb-16 lg:pb-28">
    <div class="max-w-lg">
      <p class="text-[10px] tracking-[0.45em] uppercase text-ivory-400/45 mb-7">Dublin, Ireland</p>
      <h1
        class="font-serif font-light italic text-ivory-50 leading-[1.04] mb-8"
        style="font-size: clamp(3rem, 7vw, 5.5rem);"
      >
        Private car<br />service.
      </h1>
      <p class="text-stone-300/75 text-sm leading-relaxed mb-10 max-w-xs">
        Arrivals, departures, and every journey between —<br class="hidden sm:block" />handled without compromise.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-3 text-[11px] tracking-[0.28em] uppercase text-ivory-200 link-underline"
      >
        Reserve a car
        <span class="text-brass-500 not-italic" style="font-family: inherit;">&#8594;</span>
      </a>
    </div>
  </div>

  <!-- Discreet bottom-right label -->
  <p class="absolute bottom-6 right-6 lg:right-16 text-[9px] tracking-[0.3em] uppercase text-stone-700">
    Est. Dublin
  </p>
</section>
