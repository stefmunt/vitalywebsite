---
/*
  Trust Strip — horizontal row of verifiable credentials immediately below hero.
  PLACEHOLDERS:
  - googleRating: replace with live rating from Google Business Profile
  - googleReviewCount: replace with live count
  - googleProfileUrl: replace with actual Google Business Profile URL
  - psvLicence: replace with actual PSV licence number
  - yearsInBusiness: replace with actual number of years
  - journeyCount: replace with actual or conservative count
*/

const trust = [
  {
    id:    'google',
    label: '4.9 on Google',
    sub:   '([FILL IN: N] reviews)',
    icon: `<svg viewBox="0 0 24 24" class="w-5 h-5 shrink-0" aria-hidden="true">
      <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
      <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
      <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
      <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
    </svg>`,
    href: 'PLACEHOLDER_GOOGLE_BUSINESS_URL', /* PLACEHOLDER: Add Google Business Profile URL */
  },
  {
    id:    'psv',
    label: 'PSV Licence',
    sub:   '[FILL IN: Licence number]', /* PLACEHOLDER: Add PSV licence number */
    icon: `<svg class="w-5 h-5 shrink-0 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
    </svg>`,
    href: null,
  },
  {
    id:    'insured',
    label: 'Fully insured',
    sub:   'Public liability + hire & reward',
    icon: `<svg class="w-5 h-5 shrink-0 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
    </svg>`,
    href: null,
  },
  {
    id:    'years',
    label: '[FILL IN: X]+ years in Dublin', /* PLACEHOLDER: Add years operating */
    sub:   'Est. [FILL IN: year]', /* PLACEHOLDER: Add founding year */
    icon: `<svg class="w-5 h-5 shrink-0 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
    </svg>`,
    href: null,
  },
  {
    id:    'journeys',
    label: '4,000+ transfers',
    sub:   '99.2% on-time rate',
    icon: `<svg class="w-5 h-5 shrink-0 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M13 10V3L4 14h7v7l9-11h-7z"/>
    </svg>`,
    href: null,
  },
];
---

<section
  class="bg-charcoal-800 border-y border-white/8 py-4 sm:py-5 overflow-x-auto"
  aria-label="Trust credentials"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <ul
      class="flex items-center gap-6 sm:gap-8 lg:gap-10 min-w-max mx-auto
             justify-start sm:justify-center"
      role="list"
    >
      {trust.map(({ id, icon, label, sub, href }) => (
        <li class="flex items-center gap-2.5 shrink-0" id={`trust-${id}`}>
          <span set:html={icon} />
          <span class="flex flex-col leading-tight">
            {href && href !== 'PLACEHOLDER_GOOGLE_BUSINESS_URL'
              ? (
                <a
                  href={href}
                  class="text-sm font-medium text-white hover:text-gold-400 transition-colors"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${label} — opens Google Business Profile`}
                >
                  {label}
                </a>
              )
              : (
                <span class="text-sm font-medium text-white">{label}</span>
              )
            }
            <span class="text-[11px] text-white/45">{sub}</span>
          </span>
          <!-- Divider (not after last item) -->
          <span class="trust-divider ml-4 w-px h-7 bg-white/10 hidden sm:block" aria-hidden="true"></span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  /* Remove divider after last visible item */
  li:last-child .trust-divider {
    display: none;
  }
</style>
