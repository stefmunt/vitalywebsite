---
---

<section id="contact" class="py-32 px-6 lg:px-16 bg-ink-900">
  <div class="max-w-5xl">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24">

      <!-- Left: context -->
      <div class="lg:col-span-5">
        <div class="flex items-center gap-6 mb-16">
          <span class="text-[10px] tracking-[0.42em] uppercase text-stone-600 shrink-0">Reserve</span>
          <div class="h-px flex-1 bg-ink-700"></div>
        </div>

        <h2
          class="font-serif font-light italic text-ivory-100 leading-[1.08] mb-8"
          style="font-size: clamp(2rem, 3.8vw, 3rem);"
        >
          A note to<br />our concierge.
        </h2>
        <p class="text-stone-400 text-sm leading-relaxed mb-14 max-w-xs">
          Tell us what you need. We reply personally within the hour — often sooner.
        </p>

        <div class="space-y-8">
          <div>
            <p class="text-[9px] tracking-[0.4em] uppercase text-stone-700 mb-2">Telephone</p>
            <a
              href="tel:+353000000000"
              class="text-sm text-stone-300 hover:text-ivory-100 transition-colors duration-300 link-underline"
            >
              +353 00 000 0000
            </a>
          </div>
          <div>
            <p class="text-[9px] tracking-[0.4em] uppercase text-stone-700 mb-2">Email</p>
            <a
              href="mailto:info@vitalychauffeur.com"
              class="text-sm text-stone-300 hover:text-ivory-100 transition-colors duration-300 link-underline"
            >
              info@vitalychauffeur.com
            </a>
          </div>
          <div>
            <p class="text-[9px] tracking-[0.4em] uppercase text-stone-700 mb-2">Based in</p>
            <p class="text-sm text-stone-300">Dublin, Ireland</p>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div class="lg:col-span-7">

        <!-- Success state -->
        <div id="form-success" class="hidden flex-col justify-center py-16 h-full">
          <p class="text-[10px] tracking-[0.4em] uppercase text-brass-500 mb-8">Received</p>
          <p
            class="font-serif font-light italic text-ivory-100 leading-[1.2] mb-5"
            style="font-size: clamp(1.6rem, 3vw, 2.2rem);"
          >
            Thank you. Your request has been passed to Vitaly personally.
          </p>
          <p class="text-stone-500 text-sm">Expect to hear from us within the hour.</p>
        </div>

        <!-- Form -->
        <form
          id="contact-form"
          action="https://submit-form.com/pl5RDzLOQ"
          method="POST"
          class="space-y-12"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
            <div>
              <label for="name" class="form-label">Your name</label>
              <input
                id="name"
                name="name"
                type="text"
                required
                autocomplete="name"
                placeholder="First and last"
                class="form-input"
              />
            </div>
            <div>
              <label for="phone" class="form-label">Contact number</label>
              <input
                id="phone"
                name="phone"
                type="tel"
                autocomplete="tel"
                placeholder="+353 ..."
                class="form-input"
              />
            </div>
          </div>

          <div>
            <label for="email" class="form-label">Email address</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="you@example.com"
              class="form-input"
            />
          </div>

          <div>
            <label for="message" class="form-label">Your journey</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="Date, pickup location, destination, and any details that matter..."
              class="form-input resize-none"
            ></textarea>
          </div>

          <div class="flex items-center justify-between pt-2">
            <button
              type="submit"
              id="submit-btn"
              class="inline-flex items-center gap-3 text-[11px] tracking-[0.28em] uppercase text-ivory-200 hover:text-ivory-50 link-underline transition-colors duration-300 disabled:opacity-30"
            >
              Send request
              <span id="btn-arrow" class="text-brass-500">&rarr;</span>
            </button>
            <p class="hidden sm:block text-[9px] tracking-[0.2em] uppercase text-stone-700">
              Reply within the hour
            </p>
          </div>
        </form>

      </div>
    </div>
  </div>
</section>

<style>
  .form-label {
    display: block;
    font-size: 0.6rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: #635c53;
    margin-bottom: 0.75rem;
    transition: color 0.3s;
  }
  .form-input {
    display: block;
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid #2a2520;
    padding-bottom: 0.75rem;
    font-size: 0.875rem;
    color: #f4ede0;
    outline: none;
    transition: border-color 0.3s;
    font-family: inherit;
  }
  .form-input::placeholder {
    color: #3d3730;
  }
  .form-input:focus {
    border-bottom-color: #b89a5e;
  }
  .form-input:focus ~ .form-label,
  div:focus-within > .form-label {
    color: #b89a5e;
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const arrow = document.getElementById('btn-arrow');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    if (arrow) arrow.textContent = '…';

    try {
      const data = Object.fromEntries(new FormData(form));
      await fetch(form.action, {
        method: 'POST',
        body: JSON.stringify(data),
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      });
      form.classList.add('hidden');
      success?.classList.remove('hidden');
      success?.classList.add('flex');
    } catch {
      btn.disabled = false;
      if (arrow) arrow.textContent = '→';
      alert('Something went wrong. Please call us directly.');
    }
  });
</script>
