---
import QuoteWidget from './QuoteWidget.astro';

/* PLACEHOLDER: Replace phone and WhatsApp number */
const phoneRaw     = '+353XXXXXXXXX';
const phoneDisplay = '+353 [FILL IN]';
const waNumber     = '353XXXXXXXXX';
const waMessage    = encodeURIComponent('Hi Vitaly, I\'d like to book a transfer.');
---

<!--
  BOOKING FORM + Final CTA Band
  This section contains two things:
  1. The quote widget (repeated from hero) — for users who scrolled through the whole page
  2. The full booking form — what "Book this journey" links throughout the page scroll to

  PLACEHOLDER: The booking form currently posts to /api/booking which does not exist until
  deliverable 4 (Cloudflare Worker). Until then, it shows a WhatsApp fallback.
  Once the Worker is deployed, remove the WhatsApp fallback and enable the form submit.
-->
<section
  id="booking"
  class="py-20 sm:py-24 px-4 bg-charcoal-900 border-t border-white/8"
  aria-labelledby="booking-heading"
>
  <div class="max-w-7xl mx-auto">

    <!-- Section header -->
    <div class="text-center mb-12">
      <span class="gold-rule mx-auto" aria-hidden="true"></span>
      <p class="text-gold-400 text-xs tracking-[0.35em] uppercase mb-3">Ready to go?</p>
      <h2 id="booking-heading" class="font-serif text-3xl sm:text-4xl font-bold leading-tight">
        Where are you going?
      </h2>
      <p class="mt-3 text-white/50 text-base max-w-sm mx-auto">
        Confirmation in 10 minutes. Fixed price. No surprises.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">

      <!-- Left: quick quote widget -->
      <div>
        <p class="text-white/50 text-sm mb-5">Quick price check</p>
        <QuoteWidget id="cta" dark={false} />

        <!-- Backup channels below widget -->
        <div class="mt-6 flex flex-col sm:flex-row gap-3">
          <a
            href={`tel:${phoneRaw}`}
            class="flex items-center justify-center gap-2.5 flex-1 py-3 px-5
                   border border-white/15 hover:border-gold-500/40 hover:text-gold-400
                   rounded-lg text-sm font-medium transition-colors"
            aria-label={`Call us on ${phoneDisplay}`}
            data-track="phone_clicked"
          >
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            Call us
          </a>
          <a
            href={`https://wa.me/${waNumber}?text=${waMessage}`}
            class="flex items-center justify-center gap-2.5 flex-1 py-3 px-5
                   bg-[#25D366] hover:bg-[#1da851] text-white rounded-lg text-sm font-medium transition-colors"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Open WhatsApp to book your transfer"
            data-track="whatsapp_clicked"
          >
            <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            WhatsApp
          </a>
        </div>
      </div>

      <!-- Right: Full booking form -->
      <div>
        <p class="text-white/50 text-sm mb-5">Or complete a booking request</p>

        <!-- Success state (hidden until form submitted) -->
        <div
          id="booking-success"
          class="hidden flex-col items-center justify-center text-center
                 py-16 px-6 bg-charcoal-800 border border-white/8 rounded-xl gap-5"
          role="alert"
          aria-live="polite"
        >
          <div class="w-14 h-14 rounded-full bg-gold-500/10 border border-gold-500/30
                      flex items-center justify-center">
            <svg class="w-7 h-7 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.5 12.75l6 6 9-13.5"/>
            </svg>
          </div>
          <div>
            <h3 class="font-serif text-2xl font-bold mb-2">Booking request received</h3>
            <p class="text-white/55 text-sm leading-relaxed">
              We'll confirm availability and price within 10 minutes.
              Check your phone — we may text or WhatsApp you directly.
            </p>
          </div>
        </div>

        <!-- Booking form -->
        <!--
          PLACEHOLDER: The form action="/api/booking" will 404 until deliverable 4
          (Cloudflare Worker) is deployed. The JS below intercepts the submit
          and shows an error with a WhatsApp fallback until the endpoint is live.
        -->
        <form
          id="booking-form"
          action="/api/booking"
          method="POST"
          novalidate
          class="bg-charcoal-800 border border-white/8 rounded-xl p-7 space-y-4"
          aria-label="Booking request form"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="booking-name" class="block text-xs text-white/45 uppercase tracking-widest mb-1.5">
                Full name <span class="text-gold-400" aria-hidden="true">*</span>
              </label>
              <input
                id="booking-name"
                name="name"
                type="text"
                required
                autocomplete="name"
                placeholder="Your full name"
                class="w-full bg-charcoal-700 border border-white/10 focus:border-gold-500
                       rounded-lg px-4 py-3 text-white placeholder-white/25 text-sm outline-none transition-colors"
              />
            </div>
            <div>
              <label for="booking-phone" class="block text-xs text-white/45 uppercase tracking-widest mb-1.5">
                Mobile <span class="text-gold-400" aria-hidden="true">*</span>
              </label>
              <input
                id="booking-phone"
                name="phone"
                type="tel"
                required
                autocomplete="tel"
                placeholder="+353 XX XXX XXXX"
                class="w-full bg-charcoal-700 border border-white/10 focus:border-gold-500
                       rounded-lg px-4 py-3 text-white placeholder-white/25 text-sm outline-none transition-colors"
              />
            </div>
          </div>

          <div>
            <label for="booking-email" class="block text-xs text-white/45 uppercase tracking-widest mb-1.5">
              Email <span class="text-gold-400" aria-hidden="true">*</span>
            </label>
            <input
              id="booking-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="you@company.com"
              class="w-full bg-charcoal-700 border border-white/10 focus:border-gold-500
                     rounded-lg px-4 py-3 text-white placeholder-white/25 text-sm outline-none transition-colors"
            />
          </div>

          <div>
            <label for="booking-service" class="block text-xs text-white/45 uppercase tracking-widest mb-1.5">
              Service type <span class="text-gold-400" aria-hidden="true">*</span>
            </label>
            <select
              id="booking-service"
              name="service"
              required
              class="w-full bg-charcoal-700 border border-white/10 focus:border-gold-500
                     rounded-lg px-4 py-3 text-white text-sm outline-none transition-colors appearance-none cursor-pointer"
            >
              <option value="">Select service type…</option>
              <option value="Airport Transfer">Airport Transfer</option>
              <option value="Corporate Travel">Corporate Travel</option>
              <option value="VIP &amp; Luxury">VIP &amp; Luxury</option>
              <option value="Private Driver — Half Day">Private Driver — Half Day (4 hrs)</option>
              <option value="Private Driver — Full Day">Private Driver — Full Day (8 hrs)</option>
              <option value="Private Driver — Multi Day">Private Driver — Multi Day</option>
              <option value="Other">Other / Custom</option>
            </select>
          </div>

          <div>
            <label for="booking-pickup" class="block text-xs text-white/45 uppercase tracking-widest mb-1.5">
              Pickup location <span class="text-gold-400" aria-hidden="true">*</span>
            </label>
            <input
              id="booking-pickup"
              name="pickup"
              type="text"
              required
              placeholder="e.g. Dublin Airport Terminal 1"
              class="w-full bg-charcoal-700 border border-white/10 focus:border-gold-500
                     rounded-lg px-4 py-3 text-white placeholder-white/25 text-sm outline-none transition-colors"
            />
          </div>

          <div>
            <label for="booking-dropoff" class="block text-xs text-white/45 uppercase tracking-widest mb-1.5">
              Drop-off location <span class="text-gold-400" aria-hidden="true">*</span>
            </label>
            <input
              id="booking-dropoff"
              name="dropoff"
              type="text"
              required
              placeholder="e.g. The Shelbourne Hotel, St Stephen's Green"
              class="w-full bg-charcoal-700 border border-white/10 focus:border-gold-500
                     rounded-lg px-4 py-3 text-white placeholder-white/25 text-sm outline-none transition-colors"
            />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="booking-date" class="block text-xs text-white/45 uppercase tracking-widest mb-1.5">
                Date <span class="text-gold-400" aria-hidden="true">*</span>
              </label>
              <input
                id="booking-date"
                name="date"
                type="date"
                required
                class="w-full bg-charcoal-700 border border-white/10 focus:border-gold-500
                       rounded-lg px-4 py-3 text-white text-sm outline-none transition-colors"
              />
            </div>
            <div>
              <label for="booking-time" class="block text-xs text-white/45 uppercase tracking-widest mb-1.5">
                Time <span class="text-gold-400" aria-hidden="true">*</span>
              </label>
              <input
                id="booking-time"
                name="time"
                type="time"
                required
                class="w-full bg-charcoal-700 border border-white/10 focus:border-gold-500
                       rounded-lg px-4 py-3 text-white text-sm outline-none transition-colors"
              />
            </div>
          </div>

          <div>
            <label for="booking-passengers" class="block text-xs text-white/45 uppercase tracking-widest mb-1.5">
              Passengers
            </label>
            <select
              id="booking-passengers"
              name="passengers"
              class="w-full bg-charcoal-700 border border-white/10 focus:border-gold-500
                     rounded-lg px-4 py-3 text-white text-sm outline-none transition-colors appearance-none cursor-pointer"
            >
              {[1,2,3,4,5,6].map(n => (
                <option value={n}>{n} passenger{n > 1 ? 's' : ''}</option>
              ))}
            </select>
          </div>

          <div>
            <label for="booking-notes" class="block text-xs text-white/45 uppercase tracking-widest mb-1.5">
              Notes (optional)
            </label>
            <textarea
              id="booking-notes"
              name="notes"
              rows={3}
              placeholder="Flight number, special requirements, guest name if booking for someone else…"
              class="w-full bg-charcoal-700 border border-white/10 focus:border-gold-500
                     rounded-lg px-4 py-3 text-white placeholder-white/25 text-sm outline-none
                     transition-colors resize-none"
            ></textarea>
          </div>

          <!-- Honeypot — hidden from humans, catches bots that fill every field -->
          <input type="text" name="_honey" style="display:none;position:absolute;left:-9999px;" tabindex="-1" autocomplete="off" aria-hidden="true" />

          <!-- Error message -->
          <div
            id="booking-error"
            class="hidden border border-red-500/30 bg-red-500/5 rounded-lg px-4 py-3"
            role="alert"
            aria-live="assertive"
          >
            <p class="text-sm text-red-400 mb-2">
              Something went wrong — please try again or book via WhatsApp.
            </p>
            <a
              href={`https://wa.me/${waNumber}?text=${waMessage}`}
              class="text-sm text-[#25D366] underline underline-offset-2 hover:text-[#1da851] transition-colors"
              target="_blank"
              rel="noopener noreferrer"
            >
              Open WhatsApp →
            </a>
          </div>

          <button
            id="booking-submit"
            type="submit"
            class="w-full py-3.5 bg-gold-500 hover:bg-gold-600 disabled:opacity-50 disabled:cursor-not-allowed
                   text-charcoal-900 font-semibold tracking-wide rounded-lg transition-colors duration-200"
          >
            Send Booking Request
          </button>
          <p class="text-xs text-white/30 text-center">
            We confirm availability within 10 minutes ·
            All prices incl. VAT · No card required to enquire
          </p>
        </form>
      </div>
    </div>

  </div>
</section>

<!-- JS handled by /app.js §6 (initBookingForm) -->
