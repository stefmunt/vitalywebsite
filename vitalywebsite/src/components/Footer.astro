---
const year = new Date().getFullYear();

/*
  PLACEHOLDERS — all items marked [FILL IN] must be provided before launch:
  - Real Dublin address (street, area, eircode)
  - CRO (Companies Registration Office) number
  - VAT number
  - PSV licence number
  - Real phone number
  - Instagram profile URL
  - LinkedIn profile URL
  - Google Business Profile URL
  - WhatsApp number in wa.me link
*/

const phoneRaw     = '+353XXXXXXXXX'; /* PLACEHOLDER */
const phoneDisplay = '+353 [FILL IN]'; /* PLACEHOLDER */
const waNumber     = '353XXXXXXXXX'; /* PLACEHOLDER */
const waMessage    = encodeURIComponent('Hi Vitaly, I\'d like to book a transfer.');

const navGroups = [
  {
    heading: 'Services',
    links: [
      { label: 'Airport Transfers',  href: '/#services' },
      { label: 'Corporate Travel',   href: '/#services' },
      { label: 'VIP & Luxury',       href: '/#services' },
      { label: 'Private Driver',     href: '/#services' },
    ],
  },
  {
    heading: 'Information',
    links: [
      { label: 'Fleet',              href: '/#fleet' },
      { label: 'Pricing',            href: '/#pricing' },
      { label: 'How It Works',       href: '/#how-it-works' },
      { label: 'FAQ',                href: '/#faq' },
    ],
  },
  {
    heading: 'Company',
    links: [
      { label: 'About',              href: '/#about' },
      { label: 'Contact',            href: '/#booking' },
      { label: 'Privacy Policy',     href: '/privacy' },
      { label: 'Terms & Conditions', href: '/terms' }, /* PLACEHOLDER: create /terms page */
      { label: 'Cookie Policy',      href: '/cookies' }, /* PLACEHOLDER: create /cookies page */
      { label: 'Sitemap',            href: '/sitemap.xml' },
    ],
  },
];
---

<footer class="bg-charcoal-950 border-t border-white/8" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Upper footer -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1fr] gap-10 py-14">

      <!-- Brand column -->
      <div>
        <a href="/" class="flex flex-col leading-tight mb-6" aria-label="Vitaly Executive Chauffeur — home">
          <span class="font-serif text-lg font-semibold tracking-wide text-white">Vitaly</span>
          <span class="text-xs tracking-[0.25em] text-gold-400 uppercase">Executive Chauffeur</span>
        </a>

        <p class="text-white/45 text-sm leading-relaxed mb-6 max-w-xs">
          Dublin's on-time executive chauffeur service.
          Fixed-rate airport transfers from €75.
          Garda-vetted, PSV-licensed, fully insured.
        </p>

        <!-- Contact details -->
        <address class="not-italic space-y-2.5 text-sm text-white/50 mb-6">
          <!-- PLACEHOLDER: Replace with real Dublin address -->
          <p>
            [FILL IN: Street Address]<br />
            [FILL IN: Area], Dublin [FILL IN: postcode]<br />
            Ireland
          </p>
          <p>
            <a
              href={`tel:${phoneRaw}`}
              class="hover:text-gold-400 transition-colors"
              aria-label={`Call ${phoneDisplay}`}
            >
              {phoneDisplay}
            </a>
          </p>
          <p>
            <a
              href="mailto:info@vitalychauffeur.com"
              class="hover:text-gold-400 transition-colors"
            >
              info@vitalychauffeur.com
            </a>
          </p>
        </address>

        <!-- Social links -->
        <div class="flex gap-3">
          <!-- Instagram -->
          <a
            href="PLACEHOLDER_INSTAGRAM_URL"
            class="w-9 h-9 rounded-full border border-white/10 hover:border-gold-500/40
                   flex items-center justify-center text-white/50 hover:text-gold-400 transition-colors"
            aria-label="Vitaly Executive Chauffeur on Instagram"
            target="_blank"
            rel="noopener noreferrer"
          >
            <!-- PLACEHOLDER: Add real Instagram URL -->
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>

          <!-- LinkedIn -->
          <a
            href="PLACEHOLDER_LINKEDIN_URL"
            class="w-9 h-9 rounded-full border border-white/10 hover:border-gold-500/40
                   flex items-center justify-center text-white/50 hover:text-gold-400 transition-colors"
            aria-label="Vitaly Executive Chauffeur on LinkedIn"
            target="_blank"
            rel="noopener noreferrer"
          >
            <!-- PLACEHOLDER: Add real LinkedIn URL -->
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>

          <!-- WhatsApp -->
          <a
            href={`https://wa.me/${waNumber}?text=${waMessage}`}
            class="w-9 h-9 rounded-full border border-white/10 hover:border-[#25D366]/40
                   flex items-center justify-center text-white/50 hover:text-[#25D366] transition-colors"
            aria-label="Chat with us on WhatsApp"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav columns -->
      {navGroups.map(({ heading, links }) => (
        <nav aria-label={`${heading} links`}>
          <p class="text-xs font-semibold tracking-[0.2em] text-white/30 uppercase mb-5">
            {heading}
          </p>
          <ul class="space-y-3">
            {links.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-white/50 hover:text-gold-400 transition-colors"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))}

    </div>

    <!-- Divider -->
    <div class="border-t border-white/8"></div>

    <!-- Legal footer -->
    <div class="py-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 text-xs text-white/30">
      <div class="space-y-1">
        <p>
          © {year} Vitaly Executive Chauffeur. All rights reserved.
        </p>
        <p>
          <!-- PLACEHOLDER: Replace all [FILL IN] with real registration details -->
          CRO No. [FILL IN: CRO number] ·
          VAT No. IE [FILL IN: VAT number] ·
          PSV Licence [FILL IN: PSV number]
        </p>
        <p>
          Registered in Ireland.
          <!-- PLACEHOLDER: Add registered legal entity name if different from trading name -->
        </p>
      </div>

      <div class="flex flex-wrap gap-x-4 gap-y-1">
        <a href="/privacy" class="hover:text-gold-400 transition-colors">Privacy Policy</a>
        <a href="/terms"   class="hover:text-gold-400 transition-colors">Terms</a>
        <a href="/cookies" class="hover:text-gold-400 transition-colors">Cookies</a>
        <button
          id="manage-cookies-footer"
          class="hover:text-gold-400 transition-colors text-left"
          aria-label="Manage cookie preferences"
        >
          Manage Cookies
        </button>
      </div>
    </div>

  </div>
</footer>

<!-- JS handled by /app.js §3 (initCookieConsent re-open) -->
