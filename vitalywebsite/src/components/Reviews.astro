---
/*
  Reviews / Social Proof section.

  PLACEHOLDERS — all three testimonials below are structural templates.
  Before launch, Vitaly must:
  1. Identify 3 real clients willing to be quoted by full name and company.
  2. Get written permission to use their name and quote.
  3. Optionally: get permission to use their headshot (LinkedIn photo is fine with permission).
  4. Replace every [FILL IN] with real content.
  5. Replace the Google widget placeholder div with an actual embedded review widget
     (Elfsight, Google Reviews widget, or the official Google Maps widget).

  GOOGLE WIDGET:
  The div#google-reviews-widget below is a placeholder.
  Recommended: use Elfsight Google Reviews widget (elfsight.com) — paste their
  embed script in the div. Or use the Google Maps Embed API reviews tab.
*/

const testimonials = [
  {
    id:      'testimonial-1',
    name:    '[FILL IN: Full Name]',       /* PLACEHOLDER: Real client full name */
    role:    '[FILL IN: Title, Company]', /* PLACEHOLDER: e.g. "CFO, Accenture Ireland" */
    date:    '[FILL IN: Month Year]',     /* PLACEHOLDER: e.g. "February 2025" */
    rating:  5,
    quote:   '[FILL IN: Verbatim quote from client. Should be 2–4 sentences. Must include a specific detail — e.g. the journey, the occasion, or what impressed them most. Do not paraphrase. Use the client\'s own words.]',
    photo:   '/images/review-1-photo.jpg', /* PLACEHOLDER: Commission or obtain headshot with permission */
    source:  'Google',
  },
  {
    id:      'testimonial-2',
    name:    '[FILL IN: Full Name]',
    role:    '[FILL IN: Title, Company]',
    date:    '[FILL IN: Month Year]',
    rating:  5,
    quote:   '[FILL IN: Verbatim quote from client.]',
    photo:   '/images/review-2-photo.jpg', /* PLACEHOLDER */
    source:  'Google',
  },
  {
    id:      'testimonial-3',
    name:    '[FILL IN: Full Name]',
    role:    '[FILL IN: Title, Company]',
    date:    '[FILL IN: Month Year]',
    rating:  5,
    quote:   '[FILL IN: Verbatim quote from client.]',
    photo:   '/images/review-3-photo.jpg', /* PLACEHOLDER */
    source:  'Google',
  },
];

function renderStars(count: number): string {
  return '★'.repeat(count) + '☆'.repeat(5 - count);
}
---

<section
  id="reviews"
  class="py-20 sm:py-24 px-4 bg-charcoal-900"
  aria-labelledby="reviews-heading"
>
  <div class="max-w-7xl mx-auto">

    <!-- Section header -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-14">
      <div class="max-w-xl">
        <span class="gold-rule" aria-hidden="true"></span>
        <p class="text-gold-400 text-xs tracking-[0.35em] uppercase mb-3">Client reviews</p>
        <h2 id="reviews-heading" class="font-serif text-3xl sm:text-4xl font-bold leading-tight">
          What Dublin's business travellers say
        </h2>
      </div>

      <!-- Google rating summary — PLACEHOLDER: update with live numbers -->
      <div class="flex items-center gap-3 shrink-0">
        <div class="text-right">
          <p class="font-serif text-3xl font-bold text-gold-400 leading-none">
            [FILL IN]<!-- PLACEHOLDER: e.g. 4.9 -->
          </p>
          <p class="text-xs text-white/40 mt-0.5">[FILL IN: N] Google reviews</p>
        </div>
        <div>
          <p
            class="star-rating text-xl leading-none"
            aria-label="[FILL IN: rating] out of 5 stars on Google"
          >
            ★★★★★
          </p>
          <p class="text-[10px] text-white/35 mt-1 text-right">Google</p>
        </div>
      </div>
    </div>

    <!-- Cherry-picked testimonials grid -->
    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-14"
      role="list"
      aria-label="Client testimonials"
    >
      {testimonials.map(({ id, name, role, date, rating, quote, photo, source }) => (
        <blockquote
          id={id}
          class="flex flex-col p-7 bg-charcoal-800 border border-white/8
                 rounded-xl hover:border-gold-500/20 transition-colors"
          role="listitem"
        >
          <!-- Stars -->
          <p
            class="star-rating text-base mb-4"
            aria-label={`${rating} out of 5 stars`}
          >
            {renderStars(rating)}
          </p>

          <!-- Quote -->
          <p class="text-white/70 text-sm leading-relaxed flex-1 mb-6 italic">
            "{quote}"
          </p>

          <!-- Attribution -->
          <footer class="flex items-center gap-3">
            <!-- Avatar / photo -->
            <div class="w-10 h-10 rounded-full overflow-hidden bg-charcoal-700 shrink-0 border border-white/10">
              <!--
                PLACEHOLDER: Replace with real headshot once obtained.
                If no photo: show initials — remove img and use the initials div below.
              -->
              <img
                src={photo}
                alt={`Photo of ${name}`}
                width="80"
                height="80"
                class="w-full h-full object-cover"
                loading="lazy"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />
              <!-- Fallback initials (shown if photo fails to load) -->
              <div
                class="w-full h-full hidden items-center justify-center
                       bg-gold-500/10 text-gold-400 text-sm font-semibold"
                aria-hidden="true"
              >
                {name.split(' ').map((n: string) => n[0]).join('').slice(0, 2)}
              </div>
            </div>

            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-white truncate">{name}</p>
              <p class="text-xs text-white/40 truncate">{role}</p>
            </div>

            <!-- Source badge + date -->
            <div class="text-right shrink-0">
              <p class="text-[10px] text-white/35">{source}</p>
              <p class="text-[10px] text-white/25">{date}</p>
            </div>
          </footer>
        </blockquote>
      ))}
    </div>

    <!-- Live Google Reviews widget placeholder -->
    <!--
      PLACEHOLDER: Replace this entire div with a live Google Reviews widget.
      Options:
        A. Elfsight Google Reviews widget (easiest, paid) — paste their <script> + <div> here.
        B. Google Maps Embed with reviews tab (free, limited).
        C. Custom implementation using Google My Business API (most work, most control).
      Until a widget is installed, the three cherry-picked reviews above are the social proof.
    -->
    <div
      id="google-reviews-widget"
      class="rounded-xl border border-white/8 border-dashed bg-charcoal-800/50
             p-10 text-center"
      aria-label="Google Reviews widget — to be installed before launch"
    >
      <svg class="w-8 h-8 text-white/20 mx-auto mb-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      <p class="text-white/30 text-sm">
        Live Google Reviews widget to be installed here before launch.
      </p>
      <a
        href="PLACEHOLDER_GOOGLE_BUSINESS_URL"
        class="inline-block mt-3 text-xs text-gold-400/60 hover:text-gold-400 transition-colors underline underline-offset-2"
      >
        View all reviews on Google →<!-- PLACEHOLDER: Update href with real Google Business Profile URL -->
      </a>
    </div>

  </div>
</section>
