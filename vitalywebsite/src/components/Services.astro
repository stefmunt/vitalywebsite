---
const services = [
  {
    title: 'Airport Transfers',
    description:
      'Punctual, stress-free transfers to and from Dublin Airport. Flight tracking included — we adjust for delays.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
    </svg>`,
  },
  {
    title: 'Corporate Travel',
    description:
      'Reliable executive transport for business meetings, roadshows, and client entertainment across Dublin and beyond.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0 1 12 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 0 1-.673-.38m0 0A2.18 2.18 0 0 1 3 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 0 1 3.413-.387m7.5 0V5.25A2.25 2.25 0 0 0 13.5 3h-3a2.25 2.25 0 0 0-2.25 2.25v.894m7.5 0a48.667 48.667 0 0 0-7.5 0" />
    </svg>`,
  },
  {
    title: 'VIP & Luxury',
    description:
      'Red-carpet service for special occasions, events, and high-profile clients who expect nothing but the best.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
    </svg>`,
  },
  {
    title: 'Private Driver',
    description:
      'Hire a dedicated professional chauffeur for the day, evening, or multi-day engagements tailored to your schedule.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3" />
    </svg>`,
  },
];
---

<section id="services" class="py-24 px-4 bg-charcoal-800">
  <div class="max-w-6xl mx-auto">
    <!-- Heading -->
    <div class="text-center mb-16">
      <p class="text-gold-400 text-sm tracking-[0.3em] uppercase mb-4">What We Offer</p>
      <h2 class="font-serif text-4xl md:text-5xl font-bold">Our Services</h2>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {services.map(({ icon, title, description }) => (
        <div class="group p-8 border border-white/10 rounded-lg hover:border-gold-500/50 transition-colors duration-300">
          <div class="text-gold-400 mb-5" set:html={icon} />
          <h3 class="font-serif text-xl font-semibold mb-3 group-hover:text-gold-400 transition-colors duration-200">
            {title}
          </h3>
          <p class="text-white/60 text-sm leading-relaxed">{description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
