    </svg>`,
  },
  {
    id:          'private-driver',
    title:       'Private Driver — Day Hire',
    price:       'From €[FILL IN] half-day (4 hrs)', /* PLACEHOLDER: confirm half-day/day rate */
    eyebrow:     'Half-day · Full day · Multi-day',
    description: 'Your dedicated chauffeur for a half-day (4 hrs), full day (8 hrs), or multi-day engagement. Waiting time between stops is included. Ideal for site visits across Ireland, hospitality runs, or keeping a driver on-call while you work.',
    features:    ['No meter — fixed daily rate', 'Waiting time included', 'Multi-day rates available', 'All of Ireland covered'],
    cta:         'Book a Private Driver',
    ctaHref:     '/#booking?service=private-driver',
    highlight:   false,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
        d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
