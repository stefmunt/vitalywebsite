---
/*
  Services section — 4 cards with specific pricing, differentiators, and direct booking CTAs.
  PLACEHOLDERS:
  - Hourly rates marked [FILL IN] must be confirmed with Vitaly before launch.
  - Each card links to /#booking with a pre-selected service type.
*/

const services = [
  {
    id:          'airport',
    title:       'Dublin Airport Transfers',
    price:       'From €75 flat, incl. VAT',
    eyebrow:     'Most popular',
    description: 'We track your flight and wait up to 60 minutes free if it\'s delayed. Meet-and-greet at arrivals with a name board. Luggage carried from belt to car. Fixed rate — the meter never runs.',
    features:    ['Flight tracking, real-time', '60 min free wait on delays', 'Meet & greet at arrivals', 'Luggage handled door to door'],
    cta:         'Book Airport Transfer',
    ctaHref:     '/#booking?service=airport-transfer',
    highlight:   true,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
        d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/>
    </svg>`,
  },
  {
    id:          'corporate',
    title:       'Corporate Travel',
    price:       'From €[FILL IN]/hr, incl. VAT', /* PLACEHOLDER: confirm hourly rate */
    eyebrow:     'Monthly invoicing available',
    description: 'Executive transport for client meetings, roadshows, and site visits across Dublin and beyond. Approved corporate accounts receive monthly itemised invoices — every journey ready for expense claim.',
    features:    ['Monthly invoice accounts', 'Priority booking for regulars', 'Discreet, professionally presented', 'Available Mon–Sun, 5 AM–midnight'],
    cta:         'Book Corporate Travel',
    ctaHref:     '/#booking?service=corporate-travel',
    highlight:   false,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
        d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0"/>
    </svg>`,
  },
  {
    id:          'vip',
    title:       'VIP & Luxury Events',
    price:       'From €[FILL IN]/hr, incl. VAT', /* PLACEHOLDER: confirm VIP hourly rate */
    eyebrow:     'Weddings · Galas · Concierge',
    description: 'Formal arrival for weddings, charity galas, theatre nights, and hotel concierge bookings. Red-ribbon door service. Chilled water and phone chargers in every vehicle. Discretion guaranteed.',
    features:    ['Red-door arrival service', 'Chilled water + phone charger', 'Wedding car ribbon available', 'Hotel concierge accounts welcome'],
    cta:         'Book VIP Service',
    ctaHref:     '/#booking?service=vip-luxury',
    highlight:   false,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
