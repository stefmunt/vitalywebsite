---
const services = [
  {
    number: '01',
    headline: 'Arrivals & departures',
    subline: 'Dublin Airport — any terminal, any hour.',
    description:
      'Flight tracking, real-time adjustments for delays, and a driver waiting when you clear arrivals. Your first and last impression of Dublin, handled properly.',
  },
  {
    number: '02',
    headline: 'Executive travel',
    subline: 'Boardroom to boardroom, across Dublin and beyond.',
    description:
      'For business meetings, client entertainment, and roadshows where punctuality and presentation are not optional.',
  },
  {
    number: '03',
    headline: 'Private occasions',
    subline: 'Weddings, events, and evenings that matter.',
    description:
      'Discreet, impeccably presented transport for occasions where every detail will be noticed — including the car at the door.',
  },
  {
    number: '04',
    headline: 'By the day',
    subline: 'A dedicated chauffeur, entirely at your disposal.',
    description:
      'Half-day or full-day hire for those who prefer not to think about transport at all. Available for multi-day engagements.',
  },
];
---

<section id="services" class="py-32 px-6 lg:px-16 bg-ink-950">
  <div class="max-w-5xl">

    <div class="flex items-center gap-6 mb-24">
      <span class="text-[10px] tracking-[0.42em] uppercase text-stone-600 shrink-0">Services</span>
      <div class="h-px flex-1 bg-ink-700"></div>
    </div>

    <div>
      {services.map(({ number, headline, subline, description }) => (
        <a
          href="/services"
          class="group flex flex-col sm:flex-row sm:items-start gap-4 sm:gap-12 py-12 border-t border-ink-800 hover:bg-ink-800/25 transition-colors duration-500 px-4 -mx-4"
        >
          <span class="text-[11px] text-stone-700 font-sans tracking-widest shrink-0 sm:w-8 sm:mt-1">
            {number}
          </span>
          <div class="flex-1 min-w-0">
            <h3 class="font-serif font-light italic text-2xl text-ivory-100 mb-2 group-hover:text-ivory-50 transition-colors duration-300">
              {headline}
            </h3>
            <p class="text-[10px] tracking-[0.22em] uppercase text-brass-500 mb-5">{subline}</p>
            <p class="text-sm text-stone-400 leading-relaxed max-w-md">{description}</p>
          </div>
          <span
            class="hidden sm:block text-stone-700 group-hover:text-brass-500 transition-colors duration-300 text-base sm:mt-1 shrink-0"
            aria-hidden="true"
          >
            &rarr;
          </span>
        </a>
      ))}
      <div class="border-t border-ink-800"></div>
    </div>

  </div>
</section>
