---

<section
  id="services"
  class="py-20 sm:py-24 px-4 bg-charcoal-800"
  aria-labelledby="services-heading"
>
  <div class="max-w-7xl mx-auto">

    <!-- Section header -->
    <div class="max-w-xl mb-14">
      <span class="gold-rule" aria-hidden="true"></span>
      <p class="text-gold-400 text-xs tracking-[0.35em] uppercase mb-3">Services</p>
      <h2 id="services-heading" class="font-serif text-3xl sm:text-4xl font-bold leading-tight">
        Every journey, a fixed price
      </h2>
      <p class="mt-4 text-white/55 text-base leading-relaxed max-w-md">
        No estimates. No surge pricing. The price you see before you book is the price you pay.
      </p>
    </div>

    <!-- 4-column card grid -->
    <div
      class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6"
      role="list"
    >
      {services.map(({ id, icon, eyebrow, title, price, description, features, cta, ctaHref, highlight }) => (
        <article
          id={`service-${id}`}
          class:list={[
            'group flex flex-col p-7 rounded-xl border transition-colors duration-300',
            highlight
              ? 'border-gold-500/50 bg-charcoal-900 ring-1 ring-gold-500/20'
              : 'border-white/8 bg-charcoal-900 hover:border-gold-500/30',
          ]}
          role="listitem"
        >
          <!-- Eyebrow badge -->
          <p class="text-xs tracking-[0.25em] uppercase text-gold-400/80 mb-4">{eyebrow}</p>

          <!-- Icon -->
          <div class="text-gold-400 mb-4">
            <span set:html={icon} />
          </div>

          <!-- Title + price -->
          <h3 class="font-serif text-xl font-semibold mb-1 leading-snug group-hover:text-gold-400 transition-colors">
            {title}
          </h3>
          <p class="text-gold-400 font-semibold text-sm mb-4">{price}</p>

          <!-- Description -->
          <p class="text-white/55 text-sm leading-relaxed mb-5 flex-1">{description}</p>

          <!-- Feature list -->
          <ul class="space-y-1.5 mb-6" aria-label={`${title} features`}>
            {features.map(f => (
              <li class="flex items-start gap-2 text-sm text-white/60">
                <svg class="w-3.5 h-3.5 text-gold-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href={ctaHref}
            class:list={[
              'inline-flex items-center justify-center gap-2 py-3 px-5 rounded-lg text-sm font-semibold',
              'tracking-wide transition-colors duration-200 mt-auto',
              highlight
                ? 'bg-gold-500 hover:bg-gold-600 text-charcoal-900'
                : 'border border-white/15 hover:border-gold-500/50 hover:text-gold-400',
            ]}
            aria-label={`${cta} — goes to booking form`}
          >
            {cta}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
        </article>
      ))}
    </div>

    <!-- Pricing anchor note -->
    <p class="mt-8 text-white/30 text-xs text-center">
      All prices include Irish VAT at the applicable rate. ·
      <a href="/#pricing" class="underline underline-offset-2 hover:text-gold-400 transition-colors">
        View full pricing table →
      </a>
    </p>

  </div>
</section>
