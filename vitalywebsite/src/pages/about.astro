---
import BaseLayout from '../layouts/BaseLayout.astro';
import WhyUs from '../components/WhyUs.astro';
import Testimonials from '../components/Testimonials.astro';
---

<BaseLayout
  title="About"
  description="Vitaly Executive Chauffeur — Dublin's private car service, built on discretion, precision, and a genuine standard of care."
>
  <section class="pt-44 pb-20 px-6 lg:px-16 bg-ink-950">
    <div class="max-w-5xl">
      <p class="text-[10px] tracking-[0.42em] uppercase text-stone-600 mb-8">Our story</p>
      <h1
        class="font-serif font-light italic text-ivory-100 leading-[1.04]"
        style="font-size: clamp(2.5rem, 6vw, 5rem);"
      >
        Built quietly,<br />on a single standard.
      </h1>
    </div>
  </section>

  <WhyUs testimonial={false} />
  <Testimonials />
</BaseLayout>
