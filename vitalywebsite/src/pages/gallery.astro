---
import BaseLayout from '../layouts/BaseLayout.astro';
import Gallery from '../components/Gallery.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout
  title="Fleet"
  description="The Vitaly fleet — premium vehicles maintained to the highest standard for executive travel in Dublin."
>
  <section class="pt-44 pb-20 px-6 lg:px-16 bg-ink-950">
    <div class="max-w-5xl">
      <p class="text-[10px] tracking-[0.42em] uppercase text-stone-600 mb-8">The fleet</p>
      <h1
        class="font-serif font-light italic text-ivory-100 leading-[1.04]"
        style="font-size: clamp(2.5rem, 6vw, 5rem);"
      >
        Vehicles that<br />reflect the standard.
      </h1>
    </div>
  </section>

  <Gallery />
  <Contact />
</BaseLayout>
