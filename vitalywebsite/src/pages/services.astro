---
import BaseLayout from '../layouts/BaseLayout.astro';
import Services from '../components/Services.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout
  title="Services"
  description="Airport transfers, corporate travel, private occasions, and full-day hire in Dublin — Vitaly Executive Chauffeur."
>
  <section class="pt-44 pb-20 px-6 lg:px-16 bg-ink-950">
    <div class="max-w-5xl">
      <p class="text-[10px] tracking-[0.42em] uppercase text-stone-600 mb-8">What we offer</p>
      <h1
        class="font-serif font-light italic text-ivory-100 leading-[1.04]"
        style="font-size: clamp(2.5rem, 6vw, 5rem);"
      >
        Every journey,<br />considered.
      </h1>
    </div>
  </section>

  <Services />
  <Contact />
</BaseLayout>
