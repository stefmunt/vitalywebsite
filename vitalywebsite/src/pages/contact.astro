---
import BaseLayout from '../layouts/BaseLayout.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout
  title="Reserve"
  description="Reserve a car or send an enquiry to Vitaly Executive Chauffeur. We reply personally within the hour."
>
  <section class="pt-44 pb-20 px-6 lg:px-16 bg-ink-900">
    <div class="max-w-5xl">
      <p class="text-[10px] tracking-[0.42em] uppercase text-stone-600 mb-8">Get in touch</p>
      <h1
        class="font-serif font-light italic text-ivory-100 leading-[1.04]"
        style="font-size: clamp(2.5rem, 6vw, 5rem);"
      >
        Reserve a car.
      </h1>
    </div>
  </section>

  <Contact />
</BaseLayout>
