---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank You"
  description="Your enquiry has been received. Vitaly Executive Chauffeur will be in touch shortly."
>
  <section class="min-h-screen flex items-center justify-center px-4 bg-charcoal-900 text-center">
    <div class="max-w-lg mx-auto">
      <div class="w-16 h-16 rounded-full bg-gold-500/10 flex items-center justify-center mx-auto mb-8">
        <svg class="w-8 h-8 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
      </div>
      <h1 class="font-serif text-4xl font-bold mb-4">Thank You</h1>
      <p class="text-white/60 text-lg leading-relaxed mb-10">
        Your enquiry has been received. We'll be in touch within the hour to confirm your booking.
      </p>
      <a
        href="/"
        class="inline-flex px-8 py-4 bg-gold-500 hover:bg-gold-600 text-charcoal-900 font-semibold tracking-wide rounded transition-colors duration-200"
      >
        Back to Home
      </a>
    </div>
  </section>
</BaseLayout>
