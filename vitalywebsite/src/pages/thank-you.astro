---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank You"
  description="Your request has been received. Vitaly Executive Chauffeur will be in touch shortly."
>
  <section class="min-h-screen flex flex-col items-start justify-center px-6 lg:px-16 bg-ink-900">
    <div class="max-w-xl">
      <p class="text-[10px] tracking-[0.42em] uppercase text-brass-500 mb-10">Received</p>
      <h1
        class="font-serif font-light italic text-ivory-100 leading-[1.04] mb-8"
        style="font-size: clamp(2.5rem, 5vw, 4rem);"
      >
        Thank you.<br />We'll be in touch.
      </h1>
      <p class="text-stone-400 text-sm leading-relaxed mb-16 max-w-sm">
        Your request has been passed to Vitaly personally. Expect a reply within the hour — often sooner.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-3 text-[11px] tracking-[0.28em] uppercase text-ivory-200 link-underline"
      >
        Return home
        <span class="text-brass-500">&rarr;</span>
      </a>
    </div>
  </section>
</BaseLayout>
